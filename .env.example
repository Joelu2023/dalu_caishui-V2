# 腾讯云 COS — 从「访问管理」→「API 密钥管理」创建 SecretId / SecretKey
COS_SECRET_ID=
COS_SECRET_KEY=

# 存储桶名称（含 APPID 后缀，如 mysite-1250000000），地域选 ap-guangzhou 即广州
COS_BUCKET=
COS_REGION=ap-guangzhou

# 若桶内要放在子目录，填写如 static/ ，一般留空即可
# COS_PREFIX=

# 可选：绑定自定义域名后填写完整首页地址，仅用于部署成功后的提示
# COS_PUBLIC_URL=https://www.example.com/
